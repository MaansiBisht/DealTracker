# Gmail credentials used for sending alert emails.
# EMAIL_PASSWORD must be a Google App Password (not your regular Gmail password).
# Generate one at: https://myaccount.google.com/apppasswords
EMAIL_ADDRESS=your_email@gmail.com
EMAIL_PASSWORD=your_16_char_app_password

# Used by the Amul scraper to set delivery pincode before reading stock/price.
PINCODE=123456

# Web ops console — magic-link auth (replaces the old HTTP basic).
# SESSION_SECRET: required. Signs the session cookie. Generate with:
#   python -c 'import secrets; print(secrets.token_urlsafe(32))'
SESSION_SECRET=
# APP_BASE_URL: the public base URL of this app — used to build the link
# inside the magic-link email and to flip the Secure flag on the cookie
# (https URLs → Secure cookie). Use http://localhost:8000 for local dev.
APP_BASE_URL=http://localhost:8000
# ADMIN_EMAIL: optional. The email that auto-receives admin status on
# sign-in (sees everyone's watches and events, can stop any job, claims
# orphan rows on first login). Leave empty for "everyone is a regular user".
ADMIN_EMAIL=

# Override the default sqlite location if needed (e.g. mounted volume in Docker).
# DATABASE_URL=sqlite:////data/dealtracker.db

# Scrape cadence in seconds. Defaults are dev-friendly (30s/60s).
# Recommended for production: 3600 / 10800.
TICK_INTERVAL_PRODUCT_SEC=30
TICK_INTERVAL_HOTEL_SEC=60

# Fallback recipient — used when delivery to the watch's primary email fails
# (e.g. SMTP rejects the address). Set to empty string to disable the fallback.
FALLBACK_EMAIL=bishtmaansi004@gmail.com

# ---- Telegram bot ---------------------------------------------------------
# 1. Talk to @BotFather on Telegram → /newbot → save the token here.
# 2. Inbound /start messages arrive via webhook: on startup the app calls
#    setWebhook with `{APP_BASE_URL}/api/telegram/webhook`. Requires APP_BASE_URL
#    to be HTTPS and TELEGRAM_WEBHOOK_SECRET to be set. Local dev (http://
#    APP_BASE_URL) keeps outbound sendMessage working but pairing is disabled.
# 3. Leave TELEGRAM_BOT_TOKEN empty to disable the channel entirely.
TELEGRAM_BOT_TOKEN=
# Username appears in the deep link the UI hands to the user; if you leave
# it blank we resolve it automatically via Telegram's getMe at startup.
TELEGRAM_BOT_USERNAME=
# Pre-shared secret Telegram echoes back on every webhook POST via the
# `X-Telegram-Bot-Api-Secret-Token` header. Required to enable inbound
# pairing. Generate with:
#   python -c 'import secrets; print(secrets.token_urlsafe(32))'
TELEGRAM_WEBHOOK_SECRET=
