# Gmail credentials used for sending alert emails.
# EMAIL_PASSWORD must be a Google App Password (not your regular Gmail password).
# Generate one at: https://myaccount.google.com/apppasswords
EMAIL_ADDRESS=your_email@gmail.com
EMAIL_PASSWORD=your_16_char_app_password

# Used by the Amul scraper to set delivery pincode before reading stock/price.
PINCODE=123456

# Web ops console — HTTP basic auth.
# If both are unset the API is open (only acceptable for local dev).
WEB_USER=admin
WEB_PASS=change_me

# Override the default sqlite location if needed (e.g. mounted volume in Docker).
# DATABASE_URL=sqlite:////data/dealtracker.db

# Scrape cadence in seconds. Defaults are dev-friendly (30s/60s).
# Recommended for production: 3600 / 10800.
TICK_INTERVAL_PRODUCT_SEC=30
TICK_INTERVAL_HOTEL_SEC=60

# Fallback recipient — used when delivery to the watch's primary email fails
# (e.g. SMTP rejects the address). Set to empty string to disable the fallback.
FALLBACK_EMAIL=bishtmaansi004@gmail.com

# ---- Telegram bot ---------------------------------------------------------
# 1. Talk to @BotFather on Telegram → /newbot → save the token here.
# 2. Server long-polls Telegram for /start messages, so no public HTTPS
#    webhook setup is required (works on localhost too).
# 3. Leave empty to disable the Telegram delivery channel entirely.
TELEGRAM_BOT_TOKEN=
# Username appears in the deep link the UI hands to the user; if you leave
# it blank we resolve it automatically via Telegram's getMe at startup.
TELEGRAM_BOT_USERNAME=
