# Gmail credentials used for sending alert emails.
# EMAIL_PASSWORD must be a Google App Password (not your regular Gmail password).
# Generate one at: https://myaccount.google.com/apppasswords
EMAIL_ADDRESS=your_email@gmail.com
EMAIL_PASSWORD=your_16_char_app_password

# Used by the Amul scraper to set delivery pincode before reading stock/price.
PINCODE=123456

# Web ops console — HTTP basic auth.
# If both are unset the API is open (only acceptable for local dev).
WEB_USER=admin
WEB_PASS=change_me

# Override the default sqlite location if needed (e.g. mounted volume in Docker).
# DATABASE_URL=sqlite:////data/dealtracker.db
